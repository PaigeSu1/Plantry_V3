<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AddItemsFragment"
    android:padding="16sp">

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:hint="Item Name"
        android:id="@+id/add_item_name_field"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        app:layout_constraintTop_toTopOf="parent"
        app:startIconDrawable="@drawable/ic_search"
        app:endIconDrawable="@drawable/ic_clear_field"
        app:endIconMode="clear_text">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/add_item_name_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"/>
    </com.google.android.material.textfield.TextInputLayout>


    <!--
    TODO:
    - The interface to add a single item should be a series of inputs: https://developer.android.com/develop/ui/compose/text/user-input?textfield=state-based
    - The selection for the expiration date should be a date picker: https://developer.android.com/develop/ui/compose/components/datepickers
    -->
</androidx.constraintlayout.widget.ConstraintLayout>