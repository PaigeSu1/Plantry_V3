<?xml version="1.0" encoding="utf-8"?>

<!-- How to make the internal database look readable Use options in top right corner to see view-->

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/item_quantity"
        android:layout_weight="1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/qty"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/item_buy_date"
        android:layout_weight="2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/buy"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/item_expiration_date"
        android:layout_weight="2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/expiration"
        android:textSize="16sp"/>


        <com.google.android.material.button.MaterialButton
            style="@style/Widget.Material3.Button.IconButton"
            android:id="@+id/item_warning_icon"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:contentDescription="@string/warning_icon"
            android:src="@drawable/ic_error"/>

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.Material3.Button.IconButton"
            android:id="@+id/item_more_button"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:contentDescription="@string/show_more_options"
            app:icon="@drawable/ic_more"/>
</LinearLayout>